generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  password      String
  role          String   @default("ORGANIZER") // ORGANIZER, ADMIN
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  events        Event[]
  subscription  Subscription?
  withdrawalRequests WithdrawalRequest[]
}

model Plan {
  id            String   @id @default(uuid())
  name          String
  price         Float
  maxEvents     Int
  maxGuests     Int
  features      String   @default("[]") // JSON string
  subscriptions Subscription[]
}

model Subscription {
  id            String   @id @default(uuid())
  userId        String   @unique
  planId        String
  status        String   @default("ACTIVE") // ACTIVE, EXPIRED, PENDING
  startDate     DateTime @default(now())
  endDate       DateTime
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          Plan     @relation(fields: [planId], references: [id])
}

model Event {
  id                String   @id @default(uuid())
  userId            String
  name              String
  backgroundImageUrl String?
  zones             String   @default("[]") // JSON string
  isPaid            Boolean  @default(false)
  price             Float    @default(0)
  paymentMethod     String?  // STRIPE, MOBILE_MONEY, MANUAL
  paymentNumber     String?
  shareCode         String   @unique
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  guests            Guest[]
  badgeTemplate     BadgeTemplate?
}

model Guest {
  id                String   @id @default(uuid())
  eventId           String
  name              String
  photoUrl          String?
  generatedImageUrl String?
  status            String   @default("PENDING") // PENDING, PAID, CANCELLED
  transactionRef    String?
  submittedAt       DateTime @default(now())
  event             Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  payment           Payment?
}

model BadgeTemplate {
  id                 String  @id @default(uuid())
  eventId            String  @unique
  backgroundImageUrl String?
  zones              String  @default("[]") // JSON string
  width              Float   @default(85)
  height             Float   @default(54)
  title              String  @default("Invité")
  event              Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Payment {
  id             String        @id @default(uuid())
  guestId        String        @unique
  eventId        String
  amount         Float
  commission     Float
  netAmount      Float
  status         String        @default("PENDING") // PENDING, CONFIRMED, FAILED
  transactionRef String?
  createdAt      DateTime      @default(now())
  guest          Guest         @relation(fields: [guestId], references: [id], onDelete: Cascade)
}

model WithdrawalRequest {
  id            String   @id @default(uuid())
  userId        String
  amount        Float
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  mobileNumber  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
