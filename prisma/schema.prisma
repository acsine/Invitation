generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  password      String
  role          String   @default("ORGANIZER") // ORGANIZER, ADMIN, STAFF
  parentId      String?  // Link STAFF to an ORGANIZER
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  events        Event[]
  subscription  Subscription?
  withdrawalRequests WithdrawalRequest[]
  supportTickets     SupportTicket[]
  activityLogs       ActivityLog[]
  parent             User?     @relation("UserToStaff", fields: [parentId], references: [id])
  staff              User[]    @relation("UserToStaff")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  action    String   // e.g., "SCAN_INVITATION", "SYNC_GUESTS"
  details   String?  // JSON string
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model SupportTicket {
  id          String   @id @default(uuid())
  userId      String
  subject     String
  message     String
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  adminReply  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("support_tickets")
}

model Plan {
  id            String   @id @default(uuid())
  name          String
  price         Float
  maxEvents     Int
  maxGuests     Int
  features      String   @default("[]") // JSON string
  subscriptions Subscription[]
}

model Subscription {
  id            String   @id @default(uuid())
  userId        String   @unique
  planId        String
  status        String   @default("ACTIVE") // ACTIVE, EXPIRED, PENDING
  startDate     DateTime @default(now())
  endDate       DateTime
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          Plan     @relation(fields: [planId], references: [id])
}

model Event {
  id                String   @id @default(uuid())
  userId            String
  name              String
  backgroundImageUrl String?
  zones             String   @default("[]") // JSON string
  isPaid            Boolean  @default(false)
  price             Float    @default(0)
  paymentMethod     String?  // STRIPE, MOBILE_MONEY, MANUAL
  paymentNumber     String?
  shareCode         String   @unique
  customFields      String   @default("[]") // Config JSON: [{name, label, type, required, options}]
  uniquenessField   String   @default("phone") // 'phone' or custom field name
  attendanceDays    Int      @default(1)    // Number of check-in boxes for the report
  startDate         DateTime?
  endDate           DateTime?
  sessionsPerDay    Int      @default(1)    // Max 3
  sessionConfig     String   @default("[]") // JSON string for session times/names
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  guests            Guest[]
  badgeTemplate     BadgeTemplate?
}

model Guest {
  id                String   @id @default(uuid())
  eventId           String
  name              String
  phone             String?
  photoUrl          String?
  generatedImageUrl String?
  status            String   @default("PENDING") // PENDING, PAID, CANCELLED
  transactionRef    String?
  additionalData    String   @default("{}") // Values JSON: {field_name: value}
  attendance        String   @default("{}") // JSON string for { "d1s1": true, ... }
  submittedAt       DateTime @default(now())
  event             Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  payment           Payment?

  @@unique([eventId, phone])
}

model BadgeTemplate {
  id                 String  @id @default(uuid())
  eventId            String  @unique
  backgroundImageUrl String?
  zones              String  @default("[]") // JSON string
  width              Float   @default(85)
  height             Float   @default(54)
  title              String  @default("Invité")
  event              Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Payment {
  id             String        @id @default(uuid())
  guestId        String        @unique
  eventId        String
  amount         Float
  commission     Float
  netAmount      Float
  status         String        @default("PENDING") // PENDING, CONFIRMED, FAILED
  transactionRef String?
  createdAt      DateTime      @default(now())
  guest          Guest         @relation(fields: [guestId], references: [id], onDelete: Cascade)
}

model WithdrawalRequest {
  id            String   @id @default(uuid())
  userId        String
  amount        Float
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  mobileNumber  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
